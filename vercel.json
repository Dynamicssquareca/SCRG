{
  "version": 2,
  "builds": [
    {
      "src": "api/index.ts",
      "use": "@vercel/node"
    },
    {
      "src": "client/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "rewrites": [
    {
      "source": "/api/v1/(.*)",
      "destination": "api/index.ts"
    },
    {
      "source": "/assets/(.*)",
      "destination": "/client/assets/$1"
    },
    {
      "source": "/(.*\\.[a-z0-9]+$)",
      "destination": "/client/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/client/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/v1/cron/reminders",
      "schedule": "0 4 * * *"
    }
  ]
}
